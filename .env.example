# ============================================================
# Daraja STK Push - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=daraja_user
DB_PASSWORD=your_strong_password_here
DB_NAME=daraja_db

# Daraja Sandbox Credentials
# Get these from: https://developer.safaricom.co.ke/
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here

# STK Push Configuration
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_ACCOUNT_REF=DarajaTest
DARAJA_TRANSACTION_DESC=STK Push Payment

# Callback URL (must be publicly accessible HTTPS)
# For local dev, use ngrok: https://abc123.ngrok.io
DARAJA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/v1/payments/callback

# Daraja API Base URL (sandbox)
DARAJA_API_BASE_URL=https://sandbox.safaricom.co.ke

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
